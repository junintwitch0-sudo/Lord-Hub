-- ============================================
-- AUTO COLLECT COINS
-- ============================================

local function IsCoinPart(Part)
	if not Part or not Part:IsA("BasePart") then return false end
	
	local Name = Part.Name:lower()
	local ParentName = Part.Parent and Part.Parent.Name:lower() or ""
	
	-- Moedas de eventos especificos do Fuja do Tsunami
	local CoinPatterns = {
		-- Eventos principais
		"coin", "moeda", "cash", "money", "reward",
		-- Eventos especificos - Atuais
		"arcadecoin", "arcade",
		"galaxycoin", "galaxy",
		"radioactivecoin", "radioactive", "radioativo",
		"tradetoken", "token",
		"phantomcoin", "phantom",
		"mysterybox", "mystery",
		-- Eventos Fire and Ice
		"fireandice", "fire", "ice", "firecoin", "icecoin",
		"flamecoin", "frostcoin", "inferno", "blizzard",
		"lava", "frozen", "heat", "cold",
		-- Eventos Candy
		"candy", "candycoin", "doce", "docecoin", "chocolate",
		"lollipop", "caramelo", "gummy", "sweet", "dessert",
		"taffy", "fudge", "marshmallow",
		-- Outros eventos
		"eventcoin", "event",
		"specialcoin", "special",
		"bonuscoin", "bonus",
		"treasurecoin", "treasure",
		"goldcoin", "gold",
		"silvercoin", "silver",
		"diamondcoin", "diamond",
		"epiccoin", "epic",
		"legendcoin", "legend",
		"mythicalcoin", "mythical",
		"secretcoin", "secret",
		"rarecoin", "rare",
		"uncommon", "common",
		-- Eventos sazonais
		"halloween", "christmas", "easter", "valentines",
		"summer", "winter", "spring", "autumn",
		"seasonal", "limited", "exclusive",
		-- Outros padroes
		"collectible", "pickup",
		"drop", "loot", "item",
		"premium", "vip", "pass",
		"battle", "quest", "mission",
		"daily", "weekly", "monthly"
	}
	
	-- Verifica se o nome ou parent contem padroes de moedas
	for _, Pattern in pairs(CoinPatterns) do
		if Name:find(Pattern) or ParentName:find(Pattern) then
			return true
		end
	end
	
	-- Verifica por propriedades visuais (moedas geralmente sao pequenas e redondas)
	if Part:IsA("BasePart") then
		local Size = Part.Size
		local IsSmall = Size.X < 3 and Size.Y < 3 and Size.Z < 3
		local IsRound = Part.Shape == Enum.PartType.Ball
		
		-- Se for pequeno e redondo, pode ser uma moeda
		if IsSmall and IsRound then
			return true
		end
	end
	
	return false
end

local function StartAutoCollect()
	if AutoCollectConnection then
		AutoCollectConnection:Disconnect()
	end
	
	AutoCollectConnection = RunService.Heartbeat:Connect(function()
		if not Features.AutoCollect then return end
		
		local HRP = GetHumanoidRootPart()
		if not HRP then return end
		
		local Workspace = game:GetService("Workspace")
		
		-- Procura por coins em um raio de 150 studs (aumentado para melhor cobertura)
		local CoinsNearby = Workspace:FindPartBySphere(HRP.Position, 150)
		
		for _, Part in pairs(CoinsNearby) do
			if Part and IsCoinPart(Part) then
				-- Teleporta o coin para o player
				Part.CFrame = HRP.CFrame
			end
		end
	end)
	
	Rayfield:Notify({
		Title = "Auto Collect Ativado",
		Content = "Coletando coins automaticamente!",
		Duration = 4.5,
		Image = 4483362458,
	})
end

local function StopAutoCollect()
	if AutoCollectConnection then
		AutoCollectConnection:Disconnect()
		AutoCollectConnection = nil
	end
	
	Rayfield:Notify({
		Title = "Auto Collect Desativado",
		Content = "Auto Collect foi desligado!",
		Duration = 4.5,
		Image = 4483362458,
	})
end

-- ============================================
-- TELEPORT TO PLAYERS
-- ============================================

local function TeleportToNearestPlayer()
	local NearestPlayer = GetNearestPlayer()
	if NearestPlayer then
		local PlayerChar = NearestPlayer.Character
		if PlayerChar then
			local PlayerHRP = PlayerChar:FindFirstChild("HumanoidRootPart")
			if PlayerHRP then
				TeleportTo(PlayerHRP.Position + Vector3.new(0, 5, 0))
				Rayfield:Notify({
					Title = "Teleportado",
					Content = "Teleportado para " .. NearestPlayer.Name,
					Duration = 4.5,
					Image = 4483362458,
				})
			end
		end
	end
end

